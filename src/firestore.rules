/**
 * This ruleset enforces a security model for the "Assembleia - Mensa Brasil" application,
 * centered around a global administrator role that manages public-facing "Assembly" events.
 *
 * Core Philosophy:
 * The security model is based on a strict separation of privileges. A small group of
 * administrators has full control over creating and managing assemblies, polls, and
 * speaker queues. Regular authenticated users can view public event data and participate
 * through specific, controlled actions like voting or requesting to speak.
 *
 * Data Structure:
 * - /users/{userId}: Private user profiles, managed only by the user themselves.
 * - /admins/{userId}: An admin-only collection where the existence of a document
 *   grants global administrator privileges. This separates role data from user profiles.
 * - /assemblies/{assemblyId}: A top-level collection for events. It contains nested
 *   subcollections for polls, poll options, votes, and speaker queues.
 *
 * Key Security Decisions:
 * - Admin Role Management: Administrator status is determined by the existence of a
 *   document in the `/admins` collection, not by a mutable `role` field on a user's
 *   profile. This provides robust, non-falsifiable role-based access control.
 * - Denormalization for Authorization: Critical authorization data, such as the
 *   `administratorId` and `status` from an assembly, is denormalized (copied) into child documents
 *   like polls and votes. This avoids slow and costly `get()` calls in rules, making
 *   them more performant and secure.
 * - User Data Privacy: Users can only access their own document within the `/users`
 *   collection. Listing of all users is forbidden for non-administrators.
 * - Immutability of Finished Events: Once an assembly is marked as 'finished', it and all its
 *   sub-collections become read-only to ensure a permanent, unaltered record of the event.
 * - Default Secure Posture: Unspecified permissions are implicitly denied. Any operation
 *   not explicitly allowed (e.g., a regular user trying to delete a poll) will fail.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is a designated administrator.
     * This is determined by the existence of a document in the /admins collection.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /**
     * Checks if the currently authenticated user's ID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Verifies that a document already exists.
     * Crucial for update and delete operations to prevent acting on non-existent data.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * A composite check for update/delete operations ensuring the user is the owner
     * of an existing document.
     */
    function isOwnerOfExistingDoc(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    /**
     * A composite check for update/delete operations ensuring the user is an admin
     * acting on an existing document.
     */
    function isAdminOfExistingDoc() {
      return isAdmin() && isExistingDoc();
    }

    /**
     * Validates that the core ID field of a new user document matches its path.
     * Enforces relational integrity on creation.
     */
    function hasValidNewUserData(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Validates that only allowed fields are changed during an update.
     * It uses diff() to get the set of changed keys and ensures that immutable
     * fields like 'id', 'email', and 'createdAt' are not part of that set.
     * This allows partial updates (e.g., only changing 'name' or 'avatarDataUri').
     */
    function hasValidUpdatedUserData() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.size() > 0 && !changedKeys.hasAny(['id', 'email', 'createdAt']);
    }

    // --------------------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Manages user profile data. Each user has exclusive control over their own document.
     * @path /users/{userId}
     * @allow (get) Any signed-in user can view public profiles.
     * @allow (list) Any signed-in user can query for user profiles.
     * @principle Restricts write access to a user's own data, while allowing public read.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && hasValidNewUserData(userId);
      allow update: if isOwnerOfExistingDoc(userId) && hasValidUpdatedUserData();
      allow delete: if isOwnerOfExistingDoc(userId) || isAdminOfExistingDoc();
    }

    /**
     * @description Identifies administrators. Document existence grants admin rights.
     * @path /admins/{userId}
     * @allow (get, list) An admin can check for other admin records. A user can check for their own.
     * @allow (create) Allows the special 'admin@assembleia.dev' to self-bootstrap, and allows other admins to create new ones.
     * @allow (delete) An admin can remove another admin, but not themselves.
     * @deny (update) No client can modify this collection once a record is created.
     */
    match /admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if ((isOwner(userId) && request.auth.token.email == 'admin@assembleia.dev') || isAdmin()) && request.resource.data.keys().size() == 0;
      allow update: if false;
      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    /**
     * @description Defines assembly events. Publicly readable by all users, but only managed by administrators. Becomes read-only once finished.
     * @path /assemblies/{assemblyId}
     * @allow (list) Any authenticated user can list all assemblies.
     * @allow (update) Admins can update an assembly only if it is not finished.
     * @principle Public read with role-based writes and immutability after completion.
     */
    match /assemblies/{assemblyId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.administratorId == request.auth.uid;
      allow update: if isAdminOfExistingDoc() && request.resource.data.administratorId == resource.data.administratorId && resource.data.status != 'finished';
      allow delete: if isAdminOfExistingDoc() && resource.data.status != 'finished';
    }

    /**
     * @description Defines polls within an assembly. Becomes read-only once the parent assembly is finished.
     * @path /assemblies/{assemblyId}/polls/{pollId}
     * @principle Leverages denormalized parent status for authorization.
     */
    match /assemblies/{assemblyId}/polls/{pollId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.assemblyId == assemblyId && request.resource.data.assemblyStatus != 'finished';
      allow update: if isAdminOfExistingDoc() && request.resource.data.assemblyStatus != 'finished';
      allow delete: if isAdminOfExistingDoc() && resource.data.assemblyStatus != 'finished';
    }

    /**
     * @description Defines the specific options for a poll. Becomes read-only once the parent assembly is finished.
     * @path /assemblies/{assemblyId}/polls/{pollId}/options/{optionId}
     * @principle Ensures data integrity by restricting writes based on the denormalized parent assembly status.
     */
    match /assemblies/{assemblyId}/polls/{pollId}/options/{optionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.pollId == pollId && request.resource.data.assemblyStatus != 'finished';
      allow update: if isAdminOfExistingDoc() && request.resource.data.assemblyStatus != 'finished';
      allow delete: if isAdminOfExistingDoc() && resource.data.assemblyStatus != 'finished';
    }

    /**
     * @description Records a single vote by a user on a poll. Voting is disabled if the parent assembly is finished.
     * @path /assemblies/{assemblyId}/polls/{pollId}/votes/{voteId}
     * @deny (update, delete) A user cannot change or delete their vote once it has been cast.
     * @principle Enforces one vote per user and prevents voting in finished assemblies.
     */
    match /assemblies/{assemblyId}/polls/{pollId}/votes/{voteId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(voteId) && request.resource.data.userId == request.auth.uid && request.resource.data.pollId == pollId && request.resource.data.assemblyStatus != 'finished';
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages requests from users who want to speak. Interaction is disabled if the parent assembly is finished.
     * @path /assemblies/{assemblyId}/speakerQueue/{queueItemId}
     * @principle Hybrid model: allows user self-creation and conditional self-update, while granting full management control to administrators, all blocked if assembly is finished.
     */
    match /assemblies/{assemblyId}/speakerQueue/{queueItemId} {
      allow get: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.assemblyId == assemblyId && request.resource.data.assemblyStatus != 'finished';
      allow update: if (
          isAdminOfExistingDoc() || (
            isOwnerOfExistingDoc(resource.data.userId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasAll(['status']) &&
            request.resource.data.diff(resource.data).affectedKeys().size() == 1 &&
            request.resource.data.status == 'Com a Fala' &&
            resource.data.status == 'Entrada Autorizada'
          )
        ) && resource.data.assemblyStatus != 'finished';
      allow delete: if (isOwnerOfExistingDoc(resource.data.userId) || isAdminOfExistingDoc()) && resource.data.assemblyStatus != 'finished';
    }
  }
}
