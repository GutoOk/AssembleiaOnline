{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "avatarDataUri": {
          "type": "string",
          "description": "A data URI for the user's avatar image."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user profile was created."
        }
      },
      "required": ["id", "name", "email"]
    },
    "Assembly": {
      "title": "Assembly",
      "type": "object",
      "description": "Represents an assembly meeting.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "youtubeUrl": { "type": "string", "format": "uri" },
        "imageUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["scheduled", "live", "finished", "cancelled"] },
        "administratorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "allowProxyVoting": { "type": "boolean" },
        "maxProxiesPerUser": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zip": { "type": "string" },
            "details": { "type": "string" }
          }
        },
        "ordemDoDia": { "type": "string" }
      },
      "required": ["title", "description", "date", "status", "administratorId"]
    },
    "AtaItem": {
        "title": "Ata Item",
        "type": "object",
        "description": "An item in the assembly's minutes.",
        "properties": {
            "id": { "type": "string"},
            "assemblyId": { "type": "string" },
            "administratorId": { "type": "string"},
            "text": { "type": "string"},
            "createdAt": { "type": "string", "format": "date-time"},
            "updatedAt": { "type": "string", "format": "date-time"},
            "assemblyStatus": { "type": "string" }
        },
        "required": ["assemblyId", "administratorId", "text", "createdAt"]
    },
    "Poll": {
        "title": "Poll",
        "type": "object",
        "description": "A poll for voting in an assembly.",
        "properties": {
            "id": { "type": "string"},
            "question": { "type": "string"},
            "endDate": { "type": "string", "format": "date-time"},
            "status": { "type": "string", "enum": ["draft", "open", "closed", "annulled"]},
            "createdAt": { "type": "string", "format": "date-time"},
            "updatedAt": { "type": "string", "format": "date-time"},
            "type": { "type": "string", "enum": ["proposal", "opinion"]},
            "assemblyId": { "type": "string"},
            "administratorId": { "type": "string"},
            "assemblyStatus": { "type": "string" },
            "annulmentReason": { "type": "string" },
            "annulledBy": { "type": "string" },
            "annulledAt": { "type": "string", "format": "date-time"},
            "quorumType": { "type": "string", "enum": ["simple_majority", "absolute_majority", "two_thirds_majority"]},
            "totalActiveMembers": { "type": "number" }
        },
        "required": ["question", "endDate", "status", "createdAt", "type", "assemblyId", "administratorId", "assemblyStatus"]
    },
    "PollOption": {
      "title": "Poll Option",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "pollId": { "type": "string" },
        "assemblyId": { "type": "string" },
        "assemblyStatus": { "type": "string" }
      },
      "required": ["text", "pollId", "assemblyId"]
    },
    "Vote": {
        "title": "Vote",
        "type": "object",
        "description": "A user's vote in a poll.",
        "properties": {
            "id": { "type": "string"},
            "userId": { "type": "string"},
            "pollId": { "type": "string"},
            "assemblyId": { "type": "string"},
            "pollOptionId": { "type": "string"},
            "timestamp": { "type": "string", "format": "date-time"},
            "assemblyStatus": { "type": "string"},
            "representedUserId": { "type": "string"}
        },
        "required": ["userId", "pollId", "assemblyId", "pollOptionId", "timestamp"]
    },
    "SpeakerQueueItem": {
        "title": "Speaker Queue Item",
        "type": "object",
        "description": "An item in the speaker queue for an assembly.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string"},
            "joinedAt": { "type": "string", "format": "date-time"},
            "status": { "type": "string", "enum": ["Na Fila", "Entrada Autorizada", "Com a Fala"]},
            "assemblyId": { "type": "string"},
            "administratorId": { "type": "string"},
            "assemblyStatus": { "type": "string"}
        },
        "required": ["userId", "joinedAt", "status", "assemblyId", "administratorId"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "type": "object",
      "properties": {
          "id": { "type": "string" },
          "assemblyId": { "type": "string"},
          "userId": { "type": "string" },
          "text": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["assemblyId", "userId", "text", "timestamp"]
    },
    "Reaction": {
      "title": "Reaction",
      "type": "object",
      "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string"},
          "emoji": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "messageId": { "type": "string" },
          "assemblyId": { "type": "string" }
      },
      "required": ["userId", "emoji", "createdAt", "messageId", "assemblyId"]
    },
    "ProxyAssignment": {
      "title": "Proxy Assignment",
      "type": "object",
      "properties": {
          "id": { "type": "string"},
          "assemblyId": { "type": "string"},
          "grantorId": { "type": "string"},
          "proxyId": { "type": "string"},
          "createdAt": { "type": "string", "format": "date-time"}
      },
      "required": ["assemblyId", "grantorId", "proxyId", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "type": "object",
      "description": "A record of a significant action taken within an assembly.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": [
          "ASSEMBLY_CREATED",
          "ASSEMBLY_UPDATED",
          "ASSEMBLY_STARTED",
          "ASSEMBLY_ENDED",
          "POLL_CREATED",
          "POLL_ANNULLED",
          "VOTE_CAST",
          "PROXY_ASSIGNED",
          "PROXY_REVOKED",
          "ATA_ITEM_CREATED",
          "ATA_ITEM_UPDATED",
          "ADMIN_GRANTED",
          "ADMIN_REMOVED"
        ]},
        "assemblyId": { "type": "string" },
        "actorId": { "type": "string" },
        "targetId": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "assemblyId", "actorId", "createdAt"]
    },
    "MemberEmail": {
        "title": "Member Email Lookup",
        "type": "object",
        "description": "A lookup document to find a user's UID by their normalized email address.",
        "properties": {
            "uid": { "type": "string", "description": "The user's unique ID." },
            "name": { "type": "string", "description": "The user's full name." }
        },
        "required": ["uid", "name"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile information."
    },
    "/admins/{userId}": {
        "schema": {"type": "object", "properties": {}},
        "description": "Marker collection for admin users."
    },
    "/memberEmails/{email}": {
      "schema": { "$ref": "#/entities/MemberEmail" },
      "description": "Stores a mapping from a normalized user email to their UID and name for lookups."
    },
    "/assemblies/{assemblyId}": {
      "schema": { "$ref": "#/entities/Assembly" },
      "description": "Stores assembly meeting details."
    },
    "/assemblies/{assemblyId}/private/config": {
      "schema": {
        "type": "object",
        "properties": {
          "zoomUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "description": "Stores private configuration for an assembly, like the Zoom link. Accessible only by admins."
    },
    "/assemblies/{assemblyId}/ata/{ataId}": {
      "schema": { "$ref": "#/entities/AtaItem" },
      "description": "Stores items for the assembly minutes."
    },
    "/assemblies/{assemblyId}/polls/{pollId}": {
      "schema": { "$ref": "#/entities/Poll" },
      "description": "Stores polls for an assembly."
    },
    "/assemblies/{assemblyId}/polls/{pollId}/options/{optionId}": {
      "schema": { "$ref": "#/entities/PollOption" },
      "description": "Stores the options for a poll."
    },
    "/assemblies/{assemblyId}/polls/{pollId}/votes/{voteId}": {
      "schema": { "$ref": "#/entities/Vote" },
      "description": "Stores votes for a poll."
    },
    "/assemblies/{assemblyId}/speakerQueue/{queueItemId}": {
        "schema": { "$ref": "#/entities/SpeakerQueueItem" },
        "description": "Stores items in the speaker queue for an assembly."
    },
    "/assemblies/{assemblyId}/chat/{messageId}": {
        "schema": { "$ref": "#/entities/ChatMessage" },
        "description": "Stores chat messages for an assembly."
    },
    "/assemblies/{assemblyId}/chat/{messageId}/reactions/{reactionId}": {
        "schema": { "$ref": "#/entities/Reaction" },
        "description": "Stores reactions to chat messages."
    },
    "/assemblies/{assemblyId}/proxies/{grantorId}": {
      "schema": { "$ref": "#/entities/ProxyAssignment" },
      "description": "Stores proxy voting assignments for an assembly."
    },
    "/assemblies/{assemblyId}/auditLogs/{auditLogId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Stores audit log entries for an assembly."
    },
    "/users/{userId}/blockedUsers/{blockedUserId}": {
      "schema": { "type": "object", "properties": {}},
      "description": "Subcollection to store blocked users for a user."
    },
    "/assemblies/{assemblyId}/presence/{userId}": {
        "schema": { "type": "object", "properties": { "lastSeen": {"type": "string", "format": "date-time"}, "joinedAt": {"type": "string", "format": "date-time"}}},
        "description": "Stores user presence information for an assembly."
    }
  }
}
