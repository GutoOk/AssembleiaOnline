/**
 * This ruleset enforces a security model for the "Assembleia - Mensa Brasil" application,
 * centered around a global administrator role that manages public-facing "Assembly" events.
 *
 * Core Philosophy:
 * The security model is based on a strict separation of privileges. A small group of
 * administrators has full control over creating and managing assemblies, polls, and
 * speaker queues. Regular authenticated users can view public event data and participate
 * through specific, controlled actions like voting or requesting to speak.
 *
 * Data Structure:
 * - /users/{userId}: Private user profiles, managed only by the user themselves.
 * - /admins/{userId}: An admin-only collection where the existence of a document
 *   grants global administrator privileges. This separates role data from user profiles.
 * - /assemblies/{assemblyId}: A top-level collection for events. It contains nested
 *   subcollections for polls, poll options, votes, and speaker queues.
 *
 * Key Security Decisions:
 * - Admin Role Management: Administrator status is determined by the existence of a
 *   document in the `/admins` collection, not by a mutable `role` field on a user's
 *   profile. This provides robust, non-falsifiable role-based access control.
 * - Denormalization for Authorization: Critical authorization data, such as the
 *   `administratorId` from an assembly, is denormalized (copied) into child documents
 *   like polls and votes. This avoids slow and costly `get()` calls in rules, making
 *   them more performant and secure.
 * - User Data Privacy: Users can only access their own document within the `/users`
 *   collection. Listing of all users is forbidden for non-administrators.
 * - Default Secure Posture: Unspecified permissions are implicitly denied. Any operation
 *   not explicitly allowed (e.g., a regular user trying to delete a poll) will fail.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is a designated administrator.
     * This is determined by the existence of a document in the /admins collection.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /**
     * Checks if the currently authenticated user's ID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Verifies that a document already exists.
     * Crucial for update and delete operations to prevent acting on non-existent data.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * A composite check for update/delete operations ensuring the user is the owner
     * of an existing document.
     */
    function isOwnerOfExistingDoc(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    /**
     * A composite check for update/delete operations ensuring the user is an admin
     * acting on an existing document.
     */
    function isAdminOfExistingDoc() {
      return isAdmin() && isExistingDoc();
    }

    /**
     * Validates that the core ID field of a new user document matches its path.
     * Enforces relational integrity on creation.
     */
    function hasValidNewUserData(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Validates that only allowed fields are changed during an update.
     * Ensures that immutable fields like 'id', 'email', and 'createdAt' are not modified
     * by comparing the pre-update and post-update document states.
     */
    function hasValidUpdatedUserData() {
      // Allow updates to 'name' and 'avatarDataUri', but not 'id', 'email', or 'createdAt'.
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.size() > 0 && !changedKeys.hasAny(['id', 'email', 'createdAt']);
    }

    // --------------------------------------------------------------------------------
    // Collection Group Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Rules for the 'proxies' collection group.
     * @path /{path=**}/proxies/{grantorId}
     * This rule is necessary to support the `useGrantedProxies` hook which uses a
     * collection group query to find all proxies a user has granted across all assemblies.
     */
    match /{path=**}/proxies/{grantorId} {
      /**
       * @allow (list) A user can only list proxies where they are the grantor.
       * The client-side query MUST include `where('grantorId', '==', request.auth.uid)`.
       */
      allow list: if isSignedIn()
                  && request.query.filters.grantorId[0] == request.auth.uid;
    }

    // --------------------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Manages user profile data. Each user has exclusive control over their own document.
     * @path /users/{userId}
     * @allow (get) Any signed-in user can view public profiles.
     * @allow (list) Any signed-in user can query for user profiles.
     * @principle Restricts write access to a user's own data, while allowing public read.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && hasValidNewUserData(userId);
      allow update: if isOwnerOfExistingDoc(userId) && hasValidUpdatedUserData();
      allow delete: if isOwnerOfExistingDoc(userId) || isAdminOfExistingDoc();

      /**
       * @description Manages a user's block list. A user can only manage their own list.
       * @path /users/{userId}/blockedUsers/{blockedUserId}
       * @allow (read, list, create, delete) The owner of the list can manage it.
       * @deny (update) The block marker documents are empty and should not be updated.
       */
      match /blockedUsers/{blockedUserId} {
        allow read, list, create, delete: if isOwner(userId);
        allow update: if false;
      }
    }

    /**
     * @description Identifies administrators. Document existence grants admin rights.
     * @path /admins/{userId}
     * @allow (get, list) An admin can check for other admin records. A user can check for their own.
     * @allow (create) Allows the special 'admin@assembleia.dev' to self-bootstrap, and allows other admins to create new ones.
     * @allow (delete) An admin can remove another admin, but not themselves.
     * @deny (update) No client can modify this collection once a record is created.
     */
    match /admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if ((isOwner(userId) && request.auth.token.email == 'admin@assembleia.dev') || isAdmin()) && request.resource.data.keys().size() == 0;
      allow update: if false;
      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    /**
     * @description Defines assembly events. Publicly readable by all users, but only managed by administrators.
     * @path /assemblies/{assemblyId}
     * @allow (list) Any authenticated user can list all assemblies to see upcoming events.
     * @deny (create) A regular authenticated user cannot create a new assembly.
     * @principle Public read with role-based writes (Administrator).
     */
    match /assemblies/{assemblyId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.administratorId == request.auth.uid;
      allow update: if isAdminOfExistingDoc() && request.resource.data.administratorId == resource.data.administratorId;
      allow delete: if isAdminOfExistingDoc();

      /**
       * @description Manages informal chat messages for an assembly.
       * @path /assemblies/{assemblyId}/chat/{messageId}
       * @allow (create) An authenticated user can create their own messages.
       * @allow (read, list) Any authenticated user can read chat messages.
       * @deny (update, delete) Messages are immutable.
       */
      match /chat/{messageId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.assemblyId == assemblyId;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Defines polls within an assembly. Readable by users, managed by admins.
       * @path /assemblies/{assemblyId}/polls/{pollId}
       * @allow (list) An authenticated user can list the polls for an assembly they can view.
       * @deny (update) A regular user cannot change the details of a poll.
       * @principle Leverages denormalized parent context (admin ownership) for authorization.
       */
      match /polls/{pollId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isAdmin() && request.resource.data.assemblyId == assemblyId;
        allow update: if isAdminOfExistingDoc();
        allow delete: if isAdminOfExistingDoc();
      }

      /**
       * @description Defines the specific options for a poll (e.g., 'Yes', 'No'). Readable by users, managed by admins.
       * @path /assemblies/{assemblyId}/polls/{pollId}/options/{optionId}
       * @allow (get) An authenticated user can read the options for a poll they can view.
       * @deny (create) A regular user cannot add new options to a poll.
       * @principle Ensures data integrity by restricting writes on foundational poll data to administrators.
       */
      match /polls/{pollId}/options/{optionId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isAdmin() && request.resource.data.pollId == pollId;
        allow update: if isAdminOfExistingDoc();
        allow delete: if isAdminOfExistingDoc();
      }

      /**
       * @description Records a single vote by a user on a poll. Users can only create their own vote.
       * @path /assemblies/{assemblyId}/polls/{pollId}/votes/{voteId}
       * @allow (create) An authenticated user can cast a vote, where the vote ID must be their own user ID to prevent multiple votes.
       * @deny (update, delete) A user cannot change or delete their vote once it has been cast.
       * @principle Enforces document ownership for creation and immutability after the fact.
       */
      match /polls/{pollId}/votes/{voteId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn(); // QAP: Client queries MUST filter by poll status (e.g., 'closed') to show results.
        allow create: if isOwner(voteId) && request.resource.data.userId == request.auth.uid && request.resource.data.pollId == pollId;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Manages requests from users who want to speak during an assembly.
       * @path /assemblies/{assemblyId}/speakerQueue/{queueItemId}
       * @allow (create) A user can add themselves to the speaker queue.
       * @allow (update) An admin can manage the queue. A user can also update their own status to 'Com a Fala' if their entry was previously authorized by an admin.
       * @principle Hybrid model: allows user self-creation and self-update under strict conditions, while granting full management control to administrators.
       */
      match /speakerQueue/{queueItemId} {
        // Get is restricted to the owner or an admin to protect potentially sensitive fields like a zoomLink.
        allow get: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
        // List is open to all signed-in users to allow viewing the public queue order.
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.assemblyId == assemblyId;
        allow update: if isAdminOfExistingDoc() || (
          isOwnerOfExistingDoc(resource.data.userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasAll(['status']) &&
          request.resource.data.diff(resource.data).affectedKeys().size() == 1 &&
          request.resource.data.status == 'Com a Fala' &&
          resource.data.status == 'Entrada Autorizada'
        );
        allow delete: if isOwnerOfExistingDoc(resource.data.userId) || isAdminOfExistingDoc();
      }

      /**
       * @description Manages meeting minutes (Ata). Only admins can write. All signed-in users can read.
       * @path /assemblies/{assemblyId}/ata/{ataId}
       * @principle Admin-only writes, locked after assembly completion.
       */
      match /ata/{ataId} {
          allow get: if isSignedIn();
          allow list: if isSignedIn();
          allow create: if isAdmin() 
                        && request.resource.data.assemblyId == assemblyId
                        && request.resource.data.administratorId == request.auth.uid
                        && request.resource.data.assemblyStatus != 'finished';
          allow update: if isAdminOfExistingDoc() && resource.data.assemblyStatus != 'finished';
          allow delete: if isAdminOfExistingDoc() && resource.data.assemblyStatus != 'finished';
      }

      /**
       * @description Manages proxy voting assignments. A user can assign their vote to another.
       * @path /assemblies/{assemblyId}/proxies/{grantorId}
       * @allow (create) The user assigning the proxy must be the owner of the document. Can only be done for scheduled assemblies.
       * @allow (get, list) Any signed-in user can see proxy assignments for transparency.
       * @allow (delete) The user who assigned the proxy can revoke it, but only if the assembly is scheduled.
       * @deny (update) Proxies cannot be updated; they must be revoked and re-created.
       */
      match /proxies/{grantorId} {
        allow get, list: if isSignedIn();
        allow create: if isOwner(grantorId)
                      && request.resource.data.grantorId == grantorId
                      && get(/databases/$(database)/documents/assemblies/$(assemblyId)).data.status == 'scheduled';
        allow delete: if isOwner(resource.data.grantorId)
                      && get(/databases/$(database)/documents/assemblies/$(assemblyId)).data.status == 'scheduled';
        allow update: if false;
      }
    }
  }
}
