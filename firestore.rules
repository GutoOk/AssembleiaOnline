rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
    }

    match /users/{userId}/blockedUsers/{blockedUserId} {
      allow read, write: if isOwner(userId);
    }
    
    match /admins/{userId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isAdmin();
        allow write: if isAdmin();
    }

    match /assemblies/{assemblyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /ata/{ataId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /polls/{pollId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isAdmin();

        match /options/{optionId} {
          allow read, list: if isSignedIn();
          allow create, update, delete: if isAdmin();
        }

        match /votes/{voteId} {
          allow list: if isAdmin();
          // Users can read their own vote or if they are admin
          allow get: if (isOwner(resource.data.userId) || isAdmin());
          // User can create their own vote
          allow create: if isOwner(request.resource.data.userId); 
          // No one can update or delete votes
          allow update, delete: if false;
        }
      }
      
      match /speakerQueue/{queueItemId} {
        allow read, list: if isSignedIn();
        // Only owner can create (request word)
        allow create: if isOwner(request.resource.data.userId);
        // Admin can update (change status), owner can delete (cancel request)
        allow update: if isAdmin();
        allow delete: if isOwner(resource.data.userId) || isAdmin();
      }

      match /chat/{messageId} {
        allow read, list: if isSignedIn();
        allow create: if isOwner(request.resource.data.userId);
        allow update, delete: if false; // Simplification: No edits/deletes

        match /reactions/{reactionId} {
          allow read, list: if isSignedIn();
          // A user can create/delete their own reaction
          allow write: if isOwner(reactionId);
        }
      }

      match /proxies/{grantorId} {
        allow read, list: if isSignedIn();
        // A user can create/delete their own proxy assignment
        allow write: if isOwner(grantorId);
      }

      match /presence/{userId} {
        allow read, list: if isSignedIn();
        // A user can only write to their own presence document
        allow write: if isOwner(userId);
      }
    }
  }
}
