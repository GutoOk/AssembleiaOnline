rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMensaEmail() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@mensa\\.org\\.br$');
    }

    function isVerifiedMensaUser() {
      return isMensaEmail()
        && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerifiedMensaUser()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && isMensaEmail()
        && request.resource.data.email == request.auth.token.email;
      allow get: if isVerifiedMensaUser();
      allow list: if isVerifiedMensaUser();
      allow update: if (isOwner(userId) && isVerifiedMensaUser()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/blockedUsers/{blockedUserId} {
      allow read, write: if isOwner(userId) && isVerifiedMensaUser();
    }
    
    match /memberEmails/{email} {
      allow get: if isVerifiedMensaUser();
      
      allow create: if isMensaEmail()
        && request.auth.token.email == email
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string;

      allow update: if isMensaEmail()
        && request.auth.token.email == email
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.name is string;
        
      allow delete: if false;
    }

    match /admins/{userId} {
      allow get: if (isOwner(userId) && isVerifiedMensaUser()) || isAdmin();
      allow list: if isAdmin();

      allow create, update, delete: if isAdmin();
    }

    match /assemblies/{assemblyId} {
      function assemblyDoc() {
        return get(/databases/$(database)/documents/assemblies/$(assemblyId));
      }

      function userEmail() {
        return request.auth.token.email;
      }

      function hasAssemblyAccess() {
        return isAdmin()
          || (
            isVerifiedMensaUser()
            && (
              !('accessMode' in assemblyDoc().data)
              || assemblyDoc().data.accessMode == 'all_verified_members'
              || (
                assemblyDoc().data.accessMode == 'restricted_email_list'
                && exists(/databases/$(database)/documents/assemblies/$(assemblyId)/authorizedParticipants/$(userEmail()))
              )
            )
          );
      }

      allow get: if hasAssemblyAccess();
      allow list: if isVerifiedMensaUser();
      allow create, update, delete: if isAdmin();

      match /authorizedParticipants/{email} {
        allow get: if isAdmin()
          || (
            isVerifiedMensaUser()
            && request.auth.token.email == email
          );
        allow list: if isAdmin();
        allow create, update, delete: if isAdmin();
      }

      match /private/{docId} {
        allow read, write: if isAdmin();
      }
      
      match /speakerAccess/{userId} {
        allow get: if isAdmin()
          || (
            hasAssemblyAccess()
            && request.auth.uid == userId
          );
      
        allow list: if isAdmin();
      
        allow create: if isAdmin();

        allow update: if isAdmin()
          || (
            hasAssemblyAccess()
            && request.auth.uid == userId
            && userId == request.auth.uid
            && resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.expiresAt == resource.data.expiresAt
            && request.resource.data.active == false
            && request.resource.data.zoomUrl == null
            && request.resource.data.revokedBy == request.auth.uid
          );

        allow delete: if isAdmin();
      }

      match /ata/{ataId} {
        allow read, list: if hasAssemblyAccess();
        allow create, update, delete: if isAdmin();
      }

      match /polls/{pollId} {
        allow read, list: if hasAssemblyAccess();
        allow create, update, delete: if isAdmin();

        match /options/{optionId} {
          allow read, list: if hasAssemblyAccess();
          allow create, update, delete: if isAdmin();
        }

        match /votes/{voteId} {
          function pollDoc() {
            return get(/databases/$(database)/documents/assemblies/$(assemblyId)/polls/$(pollId));
          }

          function proxyDocFor(voterId) {
            return get(/databases/$(database)/documents/assemblies/$(assemblyId)/proxies/$(voterId));
          }

          function hasActiveProxyGrant() {
            return exists(/databases/$(database)/documents/assemblies/$(assemblyId)/proxies/$(request.auth.uid))
              && get(/databases/$(database)/documents/assemblies/$(assemblyId)/proxies/$(request.auth.uid)).data.status == 'active';
          }
          
          allow get, list: if hasAssemblyAccess();

          allow create: if hasAssemblyAccess()
            && request.resource.data.status == 'active'
            && request.resource.data.pollOptionId is string
            && pollDoc().data.status == 'open'
            && request.time < pollDoc().data.endDate
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.effectiveVoterId == voteId
            && request.resource.data.assemblyId == assemblyId
            && request.resource.data.pollId == pollId
            && exists(/databases/$(database)/documents/assemblies/$(assemblyId)/polls/$(pollId)/options/$(request.resource.data.pollOptionId))
            && (
              (
                voteId == request.auth.uid
                && request.resource.data.representedUserId == null
                && !hasActiveProxyGrant()
              )
              ||
              (
                request.resource.data.representedUserId == voteId
                && exists(/databases/$(database)/documents/assemblies/$(assemblyId)/proxies/$(voteId))
                && proxyDocFor(voteId).data.proxyId == request.auth.uid
                && proxyDocFor(voteId).data.status == 'active'
              )
            );

          function canActForVote() {
            return (
              (
                voteId == request.auth.uid
                && resource.data.userId == request.auth.uid
                && resource.data.representedUserId == null
                && !hasActiveProxyGrant()
              )
              ||
              (
                resource.data.representedUserId == voteId
                && exists(/databases/$(database)/documents/assemblies/$(assemblyId)/proxies/$(voteId))
                && proxyDocFor(voteId).data.proxyId == request.auth.uid
                && proxyDocFor(voteId).data.status == 'active'
              )
            );
          }

          function immutableVoteFieldsPreserved() {
            return request.resource.data.effectiveVoterId == resource.data.effectiveVoterId
              && request.resource.data.assemblyId == resource.data.assemblyId
              && request.resource.data.pollId == resource.data.pollId
              && request.resource.data.userId == resource.data.userId
              && request.resource.data.representedUserId == resource.data.representedUserId
              && request.resource.data.timestamp == resource.data.timestamp
              && request.resource.data.assemblyStatus == resource.data.assemblyStatus;
          }

          allow update: if hasAssemblyAccess()
            && resource.data.effectiveVoterId == voteId
            && immutableVoteFieldsPreserved()
            && pollDoc().data.status == 'open'
            && request.time < pollDoc().data.endDate
            && canActForVote()
            && (
              (
                resource.data.status == 'active'
                && request.resource.data.status == 'withdrawn'
                && request.resource.data.pollOptionId == null
                && request.resource.data.previousPollOptionId == resource.data.pollOptionId
                && request.resource.data.withdrawnBy == request.auth.uid
              )
              ||
              (
                resource.data.status == 'withdrawn'
                && request.resource.data.status == 'active'
                && request.resource.data.pollOptionId is string
                && exists(/databases/$(database)/documents/assemblies/$(assemblyId)/polls/$(pollId)/options/$(request.resource.data.pollOptionId))
                && request.resource.data.votedAgainBy == request.auth.uid
              )
            );

          allow delete: if false;
        }
      }

      match /speakerQueue/{queueItemId} {
        allow read, list: if hasAssemblyAccess();

        allow create: if hasAssemblyAccess()
          && isOwner(request.resource.data.userId)
          && queueItemId == request.auth.uid;

        allow update: if isAdmin()
          || (
            hasAssemblyAccess()
            && queueItemId == request.auth.uid
            && resource.data.userId == request.auth.uid
            && resource.data.status == 'Entrada Autorizada'
            && request.resource.data.status == 'Com a Fala'
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.assemblyId == resource.data.assemblyId
            && request.resource.data.administratorId == resource.data.administratorId
            && request.resource.data.assemblyStatus == resource.data.assemblyStatus
            && request.resource.data.joinedAt == resource.data.joinedAt
            && request.resource.data.speakerStartedAt is timestamp
          );

        allow delete: if isAdmin()
          || (hasAssemblyAccess() && isOwner(resource.data.userId));
      }

      match /chat/{messageId} {
        allow read, list: if hasAssemblyAccess();

        allow create: if hasAssemblyAccess()
          && isOwner(request.resource.data.userId)
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow update, delete: if false;

        match /reactions/{reactionId} {
          allow read, list: if hasAssemblyAccess();

          allow create, update, delete: if hasAssemblyAccess()
            && reactionId == request.auth.uid
            && request.resource.data.userId == request.auth.uid;
        }
      }

      match /proxies/{grantorId} {
        function assemblyIsScheduled() {
          return assemblyDoc().data.status == 'scheduled';
        }

        function isCreatingOwnProxy() {
          return grantorId == request.auth.uid
            && request.resource.data.grantorId == request.auth.uid
            && request.resource.data.assemblyId == assemblyId
            && request.resource.data.proxyId != request.auth.uid
            && request.resource.data.status == 'active';
        }

        allow read, list: if hasAssemblyAccess();

        allow create: if hasAssemblyAccess()
          && assemblyIsScheduled()
          && assemblyDoc().data.allowProxyVoting == true
          && isCreatingOwnProxy();

        allow update: if hasAssemblyAccess()
          && assemblyIsScheduled()
          && assemblyDoc().data.allowProxyVoting == true
          && grantorId == request.auth.uid
          && resource.data.grantorId == request.auth.uid
          && request.resource.data.grantorId == resource.data.grantorId
          && request.resource.data.assemblyId == resource.data.assemblyId
          && request.resource.data.createdAt == resource.data.createdAt
          && (
            (
              // Revogar procuração ativa antes do início.
              resource.data.status == 'active'
              && request.resource.data.status == 'revoked'
              && request.resource.data.proxyId == resource.data.proxyId
              && request.resource.data.revokedBy == request.auth.uid
              && request.resource.data.revokedAt is timestamp
            )

            ||

            (
              // Reativar procuração revogada antes do início.
              resource.data.status == 'revoked'
              && request.resource.data.status == 'active'
              && request.resource.data.proxyId != request.auth.uid
              && request.resource.data.revokedAt == null
              && request.resource.data.revokedBy == null
              && request.resource.data.updatedAt is timestamp
            )

            ||

            (
              // Trocar diretamente o procurador antes do início.
              resource.data.status == 'active'
              && request.resource.data.status == 'active'
              && request.resource.data.proxyId != request.auth.uid
              && request.resource.data.revokedAt == null
              && request.resource.data.revokedBy == null
              && request.resource.data.updatedAt is timestamp
            )
          );

        allow delete: if false;
      }

      match /presence/{userId} {
        allow read, list: if hasAssemblyAccess();
        allow create, update, delete: if hasAssemblyAccess() && isOwner(userId);
      }
      
      match /auditLogs/{logId} {
        allow read, list: if isAdmin();
        allow create: if hasAssemblyAccess()
          && request.resource.data.actorId == request.auth.uid
          && request.resource.data.assemblyId == assemblyId;
        allow update, delete: if false;
      }
    }
  }
}
